<!DOCTYPE html>
<html class="dark" lang="en">
  <head>
    <title><%= content_for(:title) || "LoL Matchup Advisor" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Epilogue:ital,wght@0,400;0,700;0,800;1,700;1,800&family=Manrope:wght@400;600;700&family=Space+Grotesk:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">

    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-surface text-on-surface font-body selection:bg-primary selection:text-on-primary overflow-x-hidden">
    <!-- Top Nav -->
    <nav class="flex justify-between items-center w-full px-8 h-20 backdrop-blur-md bg-surface/90 fixed top-0 z-50 shadow-[0_10px_30px_rgba(0,0,0,0.5)]">
      <div class="text-2xl font-bold tracking-tighter text-primary italic font-headline">LEAGUE OF LEGENDS</div>
      <div class="hidden md:flex items-center space-x-8 font-headline tracking-widest uppercase text-sm">
        <a href="/" class="text-primary border-b-2 border-primary pb-2 brightness-125 transition-all">PLAY</a>
        <a href="#" class="text-primary-container/60 hover:text-primary-container transition-colors">COLLECTION</a>
        <a href="#" class="text-primary-container/60 hover:text-primary-container transition-colors">STORE</a>
      </div>
      <div class="flex items-center space-x-6">
        <span class="material-symbols-outlined text-primary hover:brightness-125 cursor-pointer">notifications</span>
        <span class="material-symbols-outlined text-primary hover:brightness-125 cursor-pointer">settings</span>
      </div>
    </nav>
    <div class="bg-gradient-to-b from-surface-container to-transparent h-1 fixed top-20 w-full z-50"></div>

    <!-- Main Content -->
    <main class="pt-24 min-h-screen stage-gradient flex flex-col items-center px-4">
      <%= yield %>
    </main>
  </body>
</html>
