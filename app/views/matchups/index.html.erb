<%= form_with url: recommendations_path, method: :post, data: { controller: "matchup" }, class: "space-y-6" do |f| %>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Your Role</label>
      <%= f.select :your_role, [["Top", "top"],
                               ["Jungle", "jungle"],
                               ["Mid", "mid"],
                               ["Adc", "adc"],
                               ["Supp", "supp"] ],
                  {prompt: "Choose your role"},
                  { class: "w-full rounded-md border border-gray-300 bg-white p-2 shadow-sm focus:border-indigo-500 focus:ring-indigo-500", data: {action: "change->matchup#hideAlly"} } %>
    </div>

    <div>
      <h3 class="text-lg font-semibold text-red-600 mb-2">Enemy Team</h3>
      <div class="grid grid-cols-5 gap-2">
        <%= f.select :enemies, @champions.map { |c| [c.name, c.name] }, {prompt: "Enemy Top"}, { name: "enemies[]", class: "w-full rounded-md border border-gray-300 bg-white p-2 text-sm" } %>
        <%= f.select :enemies, @champions.map { |c| [c.name, c.name] }, {prompt: "Enemy Jungle"}, { name: "enemies[]", class: "w-full rounded-md border border-gray-300 bg-white p-2 text-sm" } %>
        <%= f.select :enemies, @champions.map { |c| [c.name, c.name] }, {prompt: "Enemy Mid"}, { name: "enemies[]", class: "w-full rounded-md border border-gray-300 bg-white p-2 text-sm" } %>
        <%= f.select :enemies, @champions.map { |c| [c.name, c.name] }, {prompt: "Enemy Adc"}, { name: "enemies[]", class: "w-full rounded-md border border-gray-300 bg-white p-2 text-sm" } %>
        <%= f.select :enemies, @champions.map { |c| [c.name, c.name] }, {prompt: "Enemy Support"}, { name: "enemies[]", class: "w-full rounded-md border border-gray-300 bg-white p-2 text-sm" } %>
      </div>
    </div>

    <div>
      <h3 class="text-lg font-semibold text-blue-600 mb-2">Ally Team</h3>
      <div class="grid grid-cols-5 gap-2">
        <%= f.select :allies, @champions.map { |c| [c.name, c.name] }, {prompt: "Ally Top"}, { name: "allies[]", data: { role: "top" }, class: "w-full rounded-md border border-gray-300 bg-white p-2 text-sm" } %>
        <%= f.select :allies, @champions.map { |c| [c.name, c.name] }, {prompt: "Ally Jungle"}, { name: "allies[]", data: { role: "jungle" }, class: "w-full rounded-md border border-gray-300 bg-white p-2 text-sm" } %>
        <%= f.select :allies, @champions.map { |c| [c.name, c.name] }, {prompt: "Ally Mid"}, { name: "allies[]", data: { role: "mid" }, class: "w-full rounded-md border border-gray-300 bg-white p-2 text-sm" } %>
        <%= f.select :allies, @champions.map { |c| [c.name, c.name] }, {prompt: "Ally Adc"}, { name: "allies[]", data: { role: "adc" }, class: "w-full rounded-md border border-gray-300 bg-white p-2 text-sm" } %>
        <%= f.select :allies, @champions.map { |c| [c.name, c.name] }, {prompt: "Ally Support"}, { name: "allies[]", data: { role: "supp" }, class: "w-full rounded-md border border-gray-300 bg-white p-2 text-sm" } %>
      </div>
    </div>

    <div>
      <h3 class="text-lg font-semibold text-purple-600 mb-2">Your Champion Pool</h3>
      <div class="grid grid-cols-3 gap-2">
        <%= f.select :pool, @champions.map { |c| [c.name, c.name] }, {prompt: "Champion 1"}, { name: "pool[]", class: "w-full rounded-md border border-gray-300 bg-white p-2 text-sm" } %>
        <%= f.select :pool, @champions.map { |c| [c.name, c.name] }, {prompt: "Champion 2"}, { name: "pool[]", class: "w-full rounded-md border border-gray-300 bg-white p-2 text-sm" } %>
        <%= f.select :pool, @champions.map { |c| [c.name, c.name] }, {prompt: "Champion 3"}, { name: "pool[]", class: "w-full rounded-md border border-gray-300 bg-white p-2 text-sm" } %>
      </div>
    </div>

    <%= f.submit "Get Recommendation", class: "w-full bg-indigo-600 text-white font-semibold py-3 px-6 rounded-md hover:bg-indigo-700 cursor-pointer" %>
<% end %>

<div id="recommendation-result" class="mt-8">
</div>
